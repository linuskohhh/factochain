# ============================================
# FactoChain Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# --- Blockchain ---
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# --- Contract Addresses (populated after deployment) ---
INVOICE_TOKEN_ADDRESS=
FUNDING_POOL_ADDRESS=
ORACLE_GATEWAY_ADDRESS=

# --- Oracle Service ---
ORACLE_PRIVATE_KEY=your_oracle_wallet_private_key_here

# --- IPFS / Pinata ---
PINATA_JWT=your_pinata_jwt_token_here
PINATA_GATEWAY=your_dedicated_gateway.mypinata.cloud

# --- Backend ---
BACKEND_PORT=4000

# --- Frontend (prefix with VITE_ for Vite access) ---
VITE_INVOICE_TOKEN_ADDRESS=
VITE_FUNDING_POOL_ADDRESS=
VITE_ORACLE_GATEWAY_ADDRESS=
